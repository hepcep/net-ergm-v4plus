> fit_nonempty_network_w_sex <-
+   load_or_run("fit_nonempty_network_w_sex", quote(
+     ergm(
+       edges_only_net ~
+         edges +
+         nodemix("sex", levels2 = -1),
+       target.stats =
+         c(
+           edges_target,
+           sex_mixing_align_order
